    s = build_ops_summary()
    top = s.get("top_opportunity") or {}
    return {
        "status": s["system_status"],
        "counts": {
            "detected": s["signals_detected"],
            "executed": s["signals_executed"],
            "resolved": s["signals_resolved"],
            "deploy_now": s["deploy_now_count"],
            "drift": s["drift_count"],
            "shocks": s["shock_count"],
            "collapse": s["collapse_count"],
        },
        "top_opportunity": top,
        "top_deploy_now": s.get("deploy_now", [])[:3],
        "top_quality": s.get("top_quality", [])[:3],
        "allocated_capital": s["allocated_capital"],
        "recommendations": s.get("recommendations", [])[:3],
    }

