def json_response(handler, payload, status=200):
    body = json.dumps(payload, indent=2).encode("utf-8")
    handler.send_response(status)
    handler.send_header("Content-Type", "application/json; charset=utf-8")
    handler.send_header("Access-Control-Allow-Origin", "*")
    handler.send_header("Access-Control-Allow-Headers", "X-API-Key, Content-Type")
    handler.send_header("Content-Length", str(len(body)))
    handler.end_headers()
    handler.wfile.write(body)

def text_response(handler, text, status=200):
    body = text.encode("utf-8")
    handler.send_response(status)
    handler.send_header("Content-Type", "text/plain; charset=utf-8")
    handler.send_header("Access-Control-Allow-Origin", "*")
    handler.send_header("Access-Control-Allow-Headers", "X-API-Key, Content-Type")
    handler.send_header("Content-Length", str(len(body)))
    handler.end_headers()
    handler.wfile.write(body)

class Handler(BaseHTTPRequestHandler):
    def _authorized(self):
        if self.path in PUBLIC_ENDPOINTS:
            return True
        if not API_KEY:
            return True
        supplied = (self.headers.get("X-API-Key") or "").strip()
        return supplied == API_KEY

    def do_OPTIONS(self):
        self.send_response(204)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Headers", "X-API-Key, Content-Type")
        self.send_header("Access-Control-Allow-Methods", "GET, OPTIONS")
        self.end_headers()

    def do_GET(self):
        if self.path == "/":
            return json_response(self, {
                "service": "SignalAtlas Intelligence API",
                "status": "ok",
                "auth_enabled": bool(API_KEY),
                "public_endpoints": sorted(PUBLIC_ENDPOINTS),
                "protected_endpoints": sorted(FILES.keys()),
            })
        if not self._authorized():
            return json_response(self, {"error": "unauthorized"}, status=401)

        if self.path == "/api/terminal":
            return json_response(self, build_terminal_payload())
        if self.path == "/api/ops-summary":
            return json_response(self, build_ops_summary())
        if self.path == "/api/ops-brief":
            return text_response(self, build_ops_brief_text())
        if self.path == "/api/tom-status":
            return json_response(self, build_tom_status())
        if self.path == "/api/tom-card":
            return text_response(self, build_tom_card())
        if self.path == "/api/run-pipeline":
            return json_response(self, run_command("./run_signalatlas_daily.sh"))
        if self.path == "/api/run-daily":
            return json_response(self, run_command("./tom_daily_run.sh"))
        if self.path == "/api/send-card":
            return json_response(self, run_command("TOM_SEND_TG=1 ./tom_send_card.sh"))
        if self.path == "/api/refresh-signals":
            return json_response(self, run_command("./run_signalatlas_daily.sh"))

        path = FILES.get(self.path)
        if not path:
            return json_response(self, {"error": "not_found", "path": self.path}, status=404)
        if not path.exists():
            return json_response(self, {"error": "file_not_ready", "path": str(path)}, status=404)
        if path.suffix == ".json":
            try:
                payload = json.loads(path.read_text(encoding="utf-8"))
            except Exception as e:
                return json_response(self, {"error": "invalid_json", "detail": str(e)}, status=500)
            return json_response(self, payload)
        return text_response(self, path.read_text(encoding="utf-8"))

    def log_message(self, format, *args):
        return

def main():
    host = "0.0.0.0"
    port = 8011
    server = HTTPServer((host, port), Handler)
    print(f"SignalAtlas Intelligence API running on http://{host}:{port} | auth_enabled={bool(API_KEY)}")
    server.serve_forever()

if __name__ == "__main__":
    main()
