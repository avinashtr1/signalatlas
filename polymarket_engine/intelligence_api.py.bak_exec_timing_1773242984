    lines.append(f"Detected {s['counts']['detected']} | Executed {s['counts']['executed']} | Resolved {s['counts']['resolved']} | Deploy {s['counts']['deploy_now']}")
    lines.append(f"Drift {s['counts']['drift']} | Shocks {s['counts']['shocks']} | Collapse {s['counts']['collapse']}")
    lines.append(f"Allocated: {float(s['allocated_capital']):.2f}")
    lines.append("")
    top = s.get("top_opportunity") or {}
    if top.get("market_name"):
        lines.append("Top Opportunity")
        lines.append(f"{top['market_name']} | {top.get('side')} | edge={float(top.get('edge_pct', 0)):.2f}% | net={float(top.get('net_edge_pct', 0)):.2f}%")
