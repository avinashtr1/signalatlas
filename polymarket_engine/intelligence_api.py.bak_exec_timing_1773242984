def read_json(path: Path):
    if not path.exists():
        return {}
    return json.loads(path.read_text(encoding="utf-8"))

def read_text(path: Path):
    if not path.exists():
        return ""
    return path.read_text(encoding="utf-8")

def run_command(cmd: str):
    try:
        subprocess.Popen(
            cmd,
            cwd="/root/.openclaw/workspace",
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            shell=True,
        )
        return {"started": True}
    except Exception as e:
        return {"started": False, "error": str(e)}

def build_terminal_payload():
    executive = read_json(BASE / "executive_brief.json")
    reputation = read_json(BASE / "signal_reputation_full.json")
    perf = read_json(BASE / "performance_analytics.json")
    resolution = read_json(BASE / "resolution_tracking.json")
    radar_live = read_json(BASE / "radar_live.json")

    resolved = int(perf.get("resolved", 0) or 0)
    wins = int(perf.get("wins", 0) or 0)
    losses = int(perf.get("losses", 0) or 0)
    win_rate = float(perf.get("win_rate", 0) or 0)

    deploy = radar_live.get("deploy_now", []) or []
    watch = radar_live.get("watchlist", []) or []
    top_live = (deploy[:1] or watch[:1] or [{}])[0]

    executive["signals_resolved"] = resolved
    executive["win_rate"] = win_rate
    executive["realized_pnl"] = wins - losses
    executive["deploy_now_count"] = len(deploy)
    executive["top_opportunity"] = {
        "market_name": top_live.get("market_name"),
        "side": top_live.get("side"),
        "edge_pct": round(float(top_live.get("total_edge", 0.0) or 0.0) * 100, 2),
        "net_edge_pct": round(float(top_live.get("expected_net_edge_pct", 0.0) or 0.0), 2),
        "adaptive_radar_score": float(top_live.get("adaptive_radar_score", 0.0) or 0.0),
        "radar_tier": top_live.get("radar_tier", "D"),
        "active_regime": top_live.get("active_regime", ""),
    }
    executive["recommendations"] = [
        f"{len(deploy)} deploy-ready signals currently available.",
        f"{len(watch)} watchlist signals currently active.",
        f"Active regime: {top_live.get('active_regime', 'unknown') or 'unknown'}."
    ]

    reputation["signals_resolved"] = resolved
    reputation["wins"] = wins
    reputation["losses"] = losses
    reputation["win_rate"] = win_rate
    reputation["realized_pnl"] = wins - losses
    reputation["resolution_rate"] = (resolved / reputation.get("signals_detected", 1)) if reputation.get("signals_detected", 0) else 0.0

    return {
        "service": "SignalAtlas Terminal API",
        "executive": executive,
        "leaderboard": read_json(BASE / "alpha_leaderboard.json"),
        "reputation": reputation,
        "allocator": read_json(BASE / "portfolio_allocator.json"),
        "drift": read_json(BASE / "probability_drift_report.json"),
        "shocks": read_json(BASE / "probability_shocks.json"),
        "liquidity": read_json(BASE / "liquidity_collapse_report.json"),
        "liquidity_collapse_v2": read_json(BASE / "liquidity_collapse_v2.json"),
        "vacuum_v2": read_json(BASE / "liquidity_vacuum_v2.json"),
        "cross_lag": read_json(BASE / "cross_market_lag.json"),
        "resolution_arb": read_json(BASE / "resolution_arbitrage.json"),
        "resolution_arbitrage_v2": read_json(BASE / "resolution_arbitrage_v2.json"),
        "microstructure": read_json(BASE / "microstructure_intelligence.json"),
        "alpha_feed": read_json(BASE / "alpha_feed.json"),
        "stale_repricing": read_json(BASE / "stale_repricing.json"),
        "signal_memory_summary": read_json(BASE / "signal_memory_summary.json"),
        "signal_memory_analytics": read_json(BASE / "signal_memory_analytics.json"),
        "module_scoring": read_json(BASE / "module_scoring.json"),
        "market_bucket_scoring": read_json(BASE / "market_bucket_scoring.json"),
        "adaptive_weights": read_json(BASE / "adaptive_weights.json"),
        "adaptive_composite": read_json(BASE / "adaptive_composite_score.json"),
        "adaptive_alpha_feed": read_json(BASE / "adaptive_alpha_feed.json"),
        "market_regime": read_json(BASE / "market_regime.json"),
        "regime_adaptive_weights": read_json(BASE / "regime_adaptive_weights.json"),
