def build_ops_summary():
    exec_ = read_json(BASE / "executive_brief.json")
    radar = read_json(BASE / "opportunity_radar.json").get("radar", {})
    quality = read_json(BASE / "alpha_quality_scores.json").get("scores", [])
    allocator = read_json(BASE / "portfolio_allocator.json")
    top = exec_.get("top_opportunity") or {}
    deploy = radar.get("deploy_now", [])
    watch = radar.get("watchlist", [])
    return {
        "system_status": exec_.get("system_status", "UNKNOWN"),
        "signals_detected": exec_.get("signals_detected", 0),
        "signals_executed": exec_.get("signals_executed", 0),
        "signals_resolved": exec_.get("signals_resolved", 0),
        "deploy_now_count": exec_.get("deploy_now_count", 0),
        "shock_count": exec_.get("shock_count", 0),
        "drift_count": exec_.get("drift_count", 0),
        "collapse_count": exec_.get("collapse_count", 0),
        "allocated_capital": exec_.get("total_allocated_capital", 0),
        "top_opportunity": {
            "market_name": top.get("market_name"),
            "side": top.get("side"),
            "edge_pct": round(float(top.get("total_edge", 0.0) or 0.0) * 100, 2),
            "net_edge_pct": round(float(top.get("expected_net_edge_pct", 0.0) or 0.0), 2),
        },
        "deploy_now": [
            {"market_name": r.get("market_name"), "edge_pct": round(float(r.get("total_edge", 0.0) or 0.0) * 100, 2)}
            for r in deploy[:5]
        ],
        "watchlist": [
            {"market_name": r.get("market_name"), "edge_pct": round(float(r.get("total_edge", 0.0) or 0.0) * 100, 2)}
            for r in watch[:5]
        ],
        "top_quality": [
            {"market_name": r.get("market_name"), "grade": r.get("grade"), "score": r.get("quality_score")}
            for r in quality[:5]
        ],
        "recommendations": exec_.get("recommendations", []),
        "allocator_summary": {
            "reference_equity": allocator.get("reference_equity", 0),
            "total_allocated_capital": allocator.get("total_allocated_capital", 0),
            "total_allocated_pct": allocator.get("total_allocated_pct", 0),
        },
    }

def build_ops_brief_text():
    s = build_ops_summary()
    lines = []
    lines.append("SIGNALATLAS OPS BRIEF")
    lines.append("")
    lines.append(f"Status: {s['system_status']}")
    lines.append(f"Signals: detected={s['signals_detected']} executed={s['signals_executed']} resolved={s['signals_resolved']}")
    lines.append(f"Deploy-Now: {s['deploy_now_count']} | Drift: {s['drift_count']} | Shocks: {s['shock_count']} | Collapse: {s['collapse_count']}")
    lines.append(f"Allocated Capital: {float(s['allocated_capital']):.2f}")
    lines.append("")
    top = s.get("top_opportunity") or {}
    if top.get("market_name"):
        lines.append("TOP OPPORTUNITY")
        lines.append(f"{top['market_name']} | side={top.get('side')} | edge={top.get('edge_pct', 0):.2f}% | net={top.get('net_edge_pct', 0):.2f}%")
        lines.append("")
    if s.get("deploy_now"):
        lines.append("DEPLOY NOW")
        for i, r in enumerate(s["deploy_now"], start=1):
            lines.append(f"{i}. {r['market_name']} | edge={r['edge_pct']:.2f}%")
        lines.append("")
    if s.get("top_quality"):
        lines.append("TOP QUALITY")
        for i, r in enumerate(s["top_quality"], start=1):
            lines.append(f"{i}. {r['market_name']} | grade={r['grade']} | score={float(r['score']):.3f}")
        lines.append("")
    if s.get("recommendations"):
        lines.append("RECOMMENDATIONS")
        for i, r in enumerate(s["recommendations"], start=1):
            lines.append(f"{i}. {r}")
    return "\n".join(lines)

